{
  "name": "r2-media-server",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted media platform on Cloudflare R2 + Workers + D1 — personal drive, client delivery, and stock footage sales.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "deploy:api": "npm run deploy --workspace apps/api"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
