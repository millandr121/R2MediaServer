{
  "name": "@r2ms/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:apply:local": "wrangler d1 execute r2-media-server --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute r2-media-server --remote --file=./schema.sql",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.100.0"
  }
}
